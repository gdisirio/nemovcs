[Nemo Action]
Name=Settings...
Comment=Show NemoVCS settings
Exec=nemovcs settings-dialog
Icon-Name=<nemovcs-icons/nemovcs/actions/nemovcs-settings.svg>
Selection=notnone
Extensions=any;
Dependencies=svn;nemovcs;
UriScheme=file
Conditions=exec nemovcs action-visible inside-backend svn %F
Terminal=false
