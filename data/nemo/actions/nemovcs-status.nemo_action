[Nemo Action]
Name=Status...
Comment=Show Git status for the selected path
Exec=nemovcs status-dialog %F
Icon-Name=<nemovcs-icons/nemovcs/apps/nemovcs.svg>
Selection=notnone
Extensions=any;
Dependencies=git;nemovcs;
UriScheme=file
Conditions=exec nemovcs action-visible inside-worktree %F
Terminal=false
