[Nemo Action]
Name=Update...
Comment=Update this Git repository
Exec=nemovcs update-dialog %F
Icon-Name=<nemovcs-icons/nemovcs/actions/nemovcs-update.svg>
Selection=notnone
Extensions=any;
Dependencies=git;nemovcs;
UriScheme=file
Conditions=exec nemovcs action-visible inside-worktree %F
Terminal=false
