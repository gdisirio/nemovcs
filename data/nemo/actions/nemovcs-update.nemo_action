[Nemo Action]
Name=Update...
Comment=Update this Git repository
Exec=nemovcs run-terminal update %F
Icon-Name=<nemovcs-icons/rabbitvcs/actions/rabbitvcs-update.svg>
Selection=notnone
Extensions=any;
Dependencies=git;nemovcs;
UriScheme=file
Conditions=exec nemovcs action-visible inside-worktree %F
Terminal=true
