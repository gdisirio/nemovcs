[Nemo Action]
Name=Commit...
Comment=Stage the selected path and open Git commit
Exec=nemovcs run-terminal commit %F
Icon-Name=<nemovcs-icons/rabbitvcs/actions/rabbitvcs-commit.svg>
Selection=notnone
Extensions=any;
Dependencies=git;nemovcs;
UriScheme=file
Conditions=exec nemovcs action-visible inside-worktree %F
Terminal=true
