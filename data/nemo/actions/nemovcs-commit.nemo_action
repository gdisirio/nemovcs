[Nemo Action]
Name=Commit...
Comment=Open the NemoVCS commit dialog
Exec=nemovcs commit-dialog %F
Icon-Name=<nemovcs-icons/rabbitvcs/actions/rabbitvcs-commit.svg>
Selection=notnone
Extensions=any;
Dependencies=git;nemovcs;
UriScheme=file
Conditions=exec nemovcs action-visible inside-worktree %F
Terminal=false
