[Nemo Action]
Name=Settings...
Comment=Show NemoVCS settings
Exec=nemovcs run-terminal settings
Icon-Name=<nemovcs-icons/rabbitvcs/actions/rabbitvcs-settings.svg>
Selection=notnone
Extensions=any;
Dependencies=git;nemovcs;
UriScheme=file
Conditions=exec nemovcs action-visible inside-worktree %F
Terminal=true
