[Nemo Action]
Name=Log...
Comment=Show Subversion log for the selected path
Exec=nemovcs log-dialog %F
Icon-Name=<nemovcs-icons/nemovcs/actions/nemovcs-show-log.svg>
Selection=notnone
Extensions=any;
Dependencies=svn;nemovcs;
UriScheme=file
Conditions=exec nemovcs action-visible inside-backend svn %F
Terminal=false
