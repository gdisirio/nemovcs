[Nemo Action]
Name=Push...
Comment=Push this Git repository
Exec=nemovcs push-dialog %F
Icon-Name=<nemovcs-icons/rabbitvcs/actions/rabbitvcs-update.svg>
Selection=notnone
Extensions=any;
Dependencies=git;nemovcs;
UriScheme=file
Conditions=exec nemovcs action-visible inside-worktree %F
Terminal=false
