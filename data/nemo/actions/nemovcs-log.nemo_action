[Nemo Action]
Name=Log...
Comment=Show Git log for the selected path
Exec=nemovcs run-terminal log %F
Icon-Name=<nemovcs-icons/rabbitvcs/actions/rabbitvcs-show_log.svg>
Selection=notnone
Extensions=any;
Dependencies=git;nemovcs;
UriScheme=file
Conditions=exec nemovcs action-visible inside-worktree %F
Terminal=true
