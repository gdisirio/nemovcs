[Nemo Action]
Name=Log...
Comment=Show Git log for the selected path
Exec=nemovcs log-dialog %F
Icon-Name=<nemovcs-icons/nemovcs/actions/nemovcs-show-log.svg>
Selection=notnone
Extensions=any;
Dependencies=git;nemovcs;
UriScheme=file
Conditions=exec nemovcs action-visible inside-worktree %F
Terminal=false
