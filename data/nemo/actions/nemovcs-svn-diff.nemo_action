[Nemo Action]
Name=Diff...
Comment=Show Subversion diff for the selected path
Exec=nemovcs diff-dialog %F
Icon-Name=<nemovcs-icons/nemovcs/actions/nemovcs-diff.svg>
Selection=notnone
Extensions=any;
Dependencies=svn;nemovcs;
UriScheme=file
Conditions=exec nemovcs action-visible inside-backend svn %F
Terminal=false
