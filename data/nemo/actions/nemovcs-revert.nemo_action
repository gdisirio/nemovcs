[Nemo Action]
Name=Revert...
Comment=Discard selected Git changes
Exec=nemovcs revert-dialog %F
Icon-Name=<nemovcs-icons/nemovcs/actions/nemovcs-update.svg>
Selection=notnone
Extensions=any;
Dependencies=git;nemovcs;
UriScheme=file
Conditions=exec nemovcs action-visible inside-backend git %F
Terminal=false
