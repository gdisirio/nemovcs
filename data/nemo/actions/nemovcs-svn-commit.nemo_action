[Nemo Action]
Name=Commit...
Comment=Open the NemoVCS Subversion commit dialog
Exec=nemovcs commit-dialog %F
Icon-Name=<nemovcs-icons/nemovcs/actions/nemovcs-commit.svg>
Selection=notnone
Extensions=any;
Dependencies=svn;nemovcs;
UriScheme=file
Conditions=exec nemovcs action-visible inside-backend svn %F
Terminal=false
