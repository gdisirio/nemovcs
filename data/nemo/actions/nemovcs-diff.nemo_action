[Nemo Action]
Name=Diff...
Comment=Show Git diff for the selected path
Exec=nemovcs run-terminal diff %F
Icon-Name=<nemovcs-icons/rabbitvcs/actions/rabbitvcs-diff.svg>
Selection=notnone
Extensions=any;
Dependencies=git;nemovcs;
UriScheme=file
Conditions=exec nemovcs action-visible inside-worktree %F
Terminal=true
