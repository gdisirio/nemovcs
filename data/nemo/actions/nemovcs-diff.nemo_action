[Nemo Action]
Name=Diff...
Comment=Open Git diff for the selected path in Meld
Exec=nemovcs diff-dialog %F
Icon-Name=<nemovcs-icons/nemovcs/actions/nemovcs-diff.svg>
Selection=notnone
Extensions=any;
Dependencies=git;nemovcs;meld;
UriScheme=file
Conditions=exec nemovcs action-visible inside-worktree %F
Terminal=false
