[Nemo Action]
Name=SVN Checkout...
Comment=Check out a Subversion repository here
Exec=nemovcs clone-dialog --vcs svn %P
Icon-Name=<nemovcs-icons/nemovcs/actions/nemovcs-commit.svg>
Selection=none
Extensions=any;
Dependencies=svn;nemovcs;
UriScheme=file
Conditions=exec nemovcs action-visible clone-target %P
Terminal=false
