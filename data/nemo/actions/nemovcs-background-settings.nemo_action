[Nemo Action]
Name=Settings...
Comment=Show NemoVCS settings
Exec=nemovcs settings-dialog
Icon-Name=<nemovcs-icons/nemovcs/actions/nemovcs-settings.svg>
Selection=none
Extensions=any;
Dependencies=git;nemovcs;
UriScheme=file
Conditions=exec nemovcs action-visible inside-backend git %P
Terminal=false
