[Nemo Action]
Name=Settings...
Comment=Show NemoVCS settings
Exec=nemovcs settings-dialog
Icon-Name=<nemovcs-icons/rabbitvcs/actions/rabbitvcs-settings.svg>
Selection=none
Extensions=any;
Dependencies=git;nemovcs;
UriScheme=file
Conditions=exec nemovcs action-visible inside-worktree %P
Terminal=false
