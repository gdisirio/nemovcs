[Nemo Action]
Name=Status...
Comment=Show Subversion status for the selected path
Exec=nemovcs status-dialog %F
Icon-Name=<nemovcs-icons/nemovcs/apps/nemovcs.svg>
Selection=notnone
Extensions=any;
Dependencies=svn;nemovcs;
UriScheme=file
Conditions=exec nemovcs action-visible inside-backend svn %F
Terminal=false
