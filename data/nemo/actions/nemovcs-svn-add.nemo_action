[Nemo Action]
Name=Add...
Comment=Add selected paths to Subversion
Exec=nemovcs stage-dialog --operation add %F
Icon-Name=<nemovcs-icons/nemovcs/actions/nemovcs-commit.svg>
Selection=notnone
Extensions=any;
Dependencies=svn;nemovcs;
UriScheme=file
Conditions=exec nemovcs action-visible inside-backend svn %F
Terminal=false
