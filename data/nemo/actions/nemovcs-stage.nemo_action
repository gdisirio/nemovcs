[Nemo Action]
Name=Stage...
Comment=Open the NemoVCS stage dialog
Exec=nemovcs stage-dialog %F
Icon-Name=<nemovcs-icons/rabbitvcs/actions/rabbitvcs-commit.svg>
Selection=notnone
Extensions=any;
Dependencies=git;nemovcs;
UriScheme=file
Conditions=exec nemovcs action-visible inside-worktree %F
Terminal=false
