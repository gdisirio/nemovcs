[Nemo Action]
Name=Stage...
Comment=Open the NemoVCS stage dialog
Exec=nemovcs stage-dialog --operation stage %F
Icon-Name=<nemovcs-icons/nemovcs/actions/nemovcs-commit.svg>
Selection=notnone
Extensions=any;
Dependencies=git;nemovcs;
UriScheme=file
Conditions=exec nemovcs action-visible inside-backend git %F
Terminal=false
