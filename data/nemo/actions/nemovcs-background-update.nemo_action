[Nemo Action]
Name=Update...
Comment=Update this Git repository
Exec=nemovcs update-dialog %P
Icon-Name=<nemovcs-icons/nemovcs/actions/nemovcs-update.svg>
Selection=none
Extensions=any;
Dependencies=git;nemovcs;
UriScheme=file
Conditions=exec nemovcs action-visible inside-worktree %P
Terminal=false
