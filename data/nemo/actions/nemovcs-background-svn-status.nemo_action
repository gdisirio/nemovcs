[Nemo Action]
Name=Status...
Comment=Show Subversion status for this folder
Exec=nemovcs status-dialog %P
Icon-Name=<nemovcs-icons/nemovcs/apps/nemovcs.svg>
Selection=none
Extensions=any;
Dependencies=svn;nemovcs;
UriScheme=file
Conditions=exec nemovcs action-visible inside-backend svn %P
Terminal=false
