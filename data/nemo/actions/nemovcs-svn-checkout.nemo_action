[Nemo Action]
Name=SVN Checkout...
Comment=Check out a Subversion repository here
Exec=nemovcs clone-dialog --vcs svn %F
Icon-Name=<nemovcs-icons/nemovcs/actions/nemovcs-commit.svg>
Selection=s
Extensions=dir;
Dependencies=svn;nemovcs;
UriScheme=file
Conditions=exec nemovcs action-visible clone-target %F
Terminal=false
